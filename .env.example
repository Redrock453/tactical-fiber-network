# Environment variables for TFN
# Copy to .env and fill in your values

# OpenAI API Key (for agent_bot.py and codex_controller.py)
OPENAI_API_KEY=

# Telegram Bot Token (for agent_bot.py)
TELEGRAM_TOKEN=

# Allowed Telegram user ID (0 = allow all)
ALLOWED_USER=0

# Working directory for code operations
WORK_DIR=/root/workspace

# OpenCode CLI path
OPENCODE_CMD=opencode

# Maximum autonomous steps
MAX_STEPS=10

# Server port (for codex_controller.py)
PORT=8100
